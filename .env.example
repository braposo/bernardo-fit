# Your Anthropic API key — set this in the Vercel/Netlify dashboard, never commit it.
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV (added automatically when you create a KV store in the Vercel dashboard).
# If these are absent, the app falls back to in-memory storage (dev only — links won't persist).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Shared secret for /admin — set a long random value in the Vercel dashboard, never commit it.
ADMIN_SECRET=
